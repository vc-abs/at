# API Keys

# Required for Gemini MCP server
GOOGLE_API_KEY=your_google_api_key_here

# Required for Vercel AI MCP server
VERCEL_AI_API_KEY=your_vercel_ai_api_key_here

# AWS credentials (required for DVC remote storage)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_DEFAULT_REGION=us-east-1

# Optional: temporary/assumed role credentials
# AWS_SESSION_TOKEN=your_aws_session_token_here
