# Project devcontainer configuration — commit this file (no secrets).
# Overrides defaults in .devcontainer/container.env.
# See container.env for all available variables.

# Project identifier used for container/volume/image naming.
# Defaults to the repository directory name if not set.
PROJECT_NAME="at"

# Project-specific API keys to collect during secrets setup.
# Format: "VAR_NAME:Human description (server-name)"
# These are ADDED to the default keys defined in container.env.
# SECRET_KEYS+=(
#   "MY_API_KEY:My service API key (my-mcp-server)"
# )

# Shared devcontainer image archive (optional).
# start-dev.sh imports from here for new developers (~30s vs ~4 min rebuild).
# SHARED_IMAGE_STORE="${SHARED_STORE}/docker"
