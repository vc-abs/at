// Generated by: seed init devcontainer — commit this file.
// Full devcontainer config lives in abs-seed/.devcontainer/devcontainer.json.
// Extensions and settings mirror abs-seed — refresh: seed init devcontainer --force <project-dir>
// Start this project with: seed run devcontainer <project-dir>
//
// Substitution tokens (replaced by seed init devcontainer):
//   at  — repository directory name
//   /shared/store  — shared store path (from global.env, default /shared/store)
{
	"image": "localhost/vsc-abs-seed-devcontainer:latest",
	"customizations": {
		"vscode": {
			"extensions": [
				// AI / Productivity
				"GitHub.copilot-chat",
				// Editor Fundamentals
				"editorconfig.editorconfig",
				"streetsidesoftware.code-spell-checker",
				// Shell / Bash
				"mads-hartmann.bash-ide-vscode",
				"foxundermoon.shell-format",
				// YAML
				"redhat.vscode-yaml",
				// Markdown
				"bierner.github-markdown-preview",
				// Python
				"ms-python.python",
				// Git
				"eamodio.gitlens",
				// Data / DVC
				"lakefs.lakefs-dvc"
			],
			"settings": {
				// Terminal
				"terminal.integrated.defaultProfile.linux": "bash",
				"terminal.integrated.profiles.linux": {
					"bash": {
						"path": "/bin/bash"
					}
				},
				// File defaults
				"files.eol": "\n",
				"files.insertFinalNewline": true,
				"files.trimTrailingWhitespace": true,
				"editor.formatOnSave": true,
				"editor.tabSize": 2,
				"editor.insertSpaces": false,
				// Shell format (foxundermoon.shell-format)
				"shellformat.flag": "-i 0 -bn",
				"[shellscript]": {
					"editor.defaultFormatter": "foxundermoon.shell-format"
				},
				"[bash]": {
					"editor.defaultFormatter": "foxundermoon.shell-format"
				},
				// Bash IDE (mads-hartmann.bash-ide-vscode)
				"bashIde.enableSourceErrorDiagnostics": true,
				// YAML (redhat.vscode-yaml)
				"yaml.validate": true,
				"yaml.format.enable": true,
				"yaml.schemas": {
					"https://json.schemastore.org/github-workflow.json": ".github/workflows/*.{yml,yaml}",
					"https://json.schemastore.org/github-action.json": ".github/actions/*/action.{yml,yaml}"
				},
				// GitLens (eamodio.gitlens)
				"gitlens.mode.active": "review",
				"gitlens.codeLens.enabled": false,
				"gitlens.currentLine.enabled": true,
				"gitlens.hovers.currentLine.over": "line",
				// Python (ms-python.python)
				// Point directly at system Python so VS Code and Copilot never try to
				// create a venv — the container itself is the isolation layer.
				"python.defaultInterpreterPath": "/usr/bin/python3",
				"python.terminal.activateEnvironment": false,
				"[python]": {
					"editor.insertSpaces": true,
					"editor.tabSize": 4
				},
				// Prevent VS Code from silently auto-upgrading extensions inside the container.
				// Extension versions track the host — update the host, then rebuild the container.
				"extensions.autoUpdate": false,
				"extensions.autoCheckUpdates": false,
				// Bypass VS Code agent tool confirmation dialogs inside the container.
				// Disabled: explicit approval required for agent tool use.
				"chat.tools.global.autoApprove": false,
				// Copilot agent — allow Claude to skip permission prompts inside the container.
				"github.copilot.chat.claudeAgent.allowDangerouslySkipPermissions": true,
				// Spell checker (streetsidesoftware.code-spell-checker)
				"cSpell.enabledLanguageIds": [
					"markdown",
					"yaml",
					"shellscript",
					"python",
					"javascript",
					"json",
					"jsonc"
				]
			}
		}
	},
	// Security: read-only root filesystem + tmpfs scratch areas.
	// Resource limits: hard caps prevent runaway processes from consuming host resources.
	"runArgs": [
		"--name=vsc-at-devcontainer-${localEnv:PROJECT_PATH_HASH}",
		"--read-only",
		// Runtime UID mapping: container agent (uid=1000) → host user, whoever they are.
		// Equivalent to --userns=keep-id:uid=1000,gid=1000 (Podman ≥4.9), spelled out for 4.3.1.
		// One image (built in abs-seed) works for all users — no per-user build needed.
		"--uidmap=0:1:1000",
		"--uidmap=1000:0:1",
		"--uidmap=1001:1001:64535",
		"--gidmap=0:1:1000",
		"--gidmap=1000:0:1",
		"--gidmap=1001:1001:64535",
		"--tmpfs=/tmp:exec,nosuid,nodev,size=512m",
		"--tmpfs=/run:exec,nosuid,nodev,size=64m",
		"--tmpfs=/var/tmp:nosuid,nodev,size=256m",
		"--tmpfs=/home/agent/.vscode-server:exec,mode=1777,size=4g",
		// Podman: uid=/gid= in tmpfs options unsupported (Docker only), use mode= only
		"--tmpfs=/root/.secrets:mode=0700,size=1m",
		"--memory=8g",
		"--memory-swap=8g",
		"--cpus=4",
		"--pids-limit=1024"
	],
	"hostRequirements": {
		"cpus": 4,
		"memory": "8gb",
		"storage": "32gb"
	},
	"workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
	"workspaceFolder": "/workspace",
	"mounts": [
		// Agent home: named volume (writable, persists across restarts)
		"source=at-agent-home,target=/home/agent,type=volume",
		"source=${localEnv:HOME}/.ssh,target=/home/agent/.ssh,type=bind,consistency=cached,readonly",
		"source=${localEnv:HOME}/.gitconfig,target=/home/agent/.gitconfig-host,type=bind,consistency=cached,readonly",
		// shared - DVC cache shared across all developers on same machine
		"source=/shared/dvc-cache,target=/shared/dvc-cache,type=bind,consistency=cached",
		// shared - Product configurations accessed by multiple projects
		"source=/shared/product,target=/shared/product,type=bind,consistency=cached",
		// shared - MCP server tools
		"source=/shared/store/gemini-mcp-server,target=/shared/store/gemini-mcp-server,type=bind,consistency=cached,readonly",
		"source=/shared/store/vercel-ai-mcp-server,target=/shared/store/vercel-ai-mcp-server,type=bind,consistency=cached,readonly",
		// shared - Package caches (survive container rebuilds)
		"source=/shared/store/cache/devcontainer/pnpm,target=/shared/store/cache/devcontainer/pnpm,type=bind,consistency=cached",
		"source=/shared/store/cache/devcontainer/uv,target=/shared/store/cache/devcontainer/uv,type=bind,consistency=cached",
		"source=/shared/store/cache/devcontainer/bun,target=/shared/store/cache/devcontainer/bun,type=bind,consistency=cached"
	],
	"containerEnv": {
		"WORKSPACEROOT": "/workspace",
		"DEBUG_LEVEL": "${localEnv:DEBUG_LEVEL:1}",
		"DVC_CACHE_DIR": "/shared/dvc-cache",
		"AWS_ACCESS_KEY_ID": "${localEnv:AWS_ACCESS_KEY_ID:}",
		"AWS_SECRET_ACCESS_KEY": "${localEnv:AWS_SECRET_ACCESS_KEY:}",
		"AWS_DEFAULT_REGION": "${localEnv:AWS_DEFAULT_REGION:us-east-1}",
		"AWS_SESSION_TOKEN": "${localEnv:AWS_SESSION_TOKEN:}",
		"DEV_TOOLS": "jq yq mlr sqlite3 duckdb rg fdfind bat fzf tree direnv age sops bun aws gh node pnpm python3 uv dvc",
		"PNPM_STORE_PATH": "/shared/store/cache/devcontainer/pnpm",
		"UV_CACHE_DIR": "/shared/store/cache/devcontainer/uv",
		"BUN_INSTALL_CACHE_DIR": "/shared/store/cache/devcontainer/bun",
		// Network proxy (sandbox-proxy). Start with: seed run sandbox-proxy start
		"HTTP_PROXY": "http://host.containers.internal:3128",
		"HTTPS_PROXY": "http://host.containers.internal:3128",
		"NO_PROXY": "localhost,127.0.0.1,.amazonaws.com"
	},
	"remoteEnv": {
		"PATH": "${containerEnv:PATH}",
		"DOTENV_FILE": "${localWorkspaceFolder}/.env"
	},
	"forwardPorts": [],
	"remoteUser": "agent",
	"updateRemoteUserUID": false,
	"initializeCommand": "bash /shared/store/devcontainer/init-host.sh"
}